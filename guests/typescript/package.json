{
  "name": "imagebase-guest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build:js": "vite build",
    "build:wasm": "jco componentize dist/index.js -w node_modules/trailbase-wasm/wit -o dist/component.wasm",
    "build": "npm run build:js && npm run build:wasm",
    "deploy": "npm run build && mkdir -p ../../traildepot/wasm && cp dist/component.wasm ../../traildepot/wasm/imagebase_guest.wasm",
    "check": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "trailbase-wasm": "^0.5.2"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.17.6",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
